# 大模型 API（OpenAI 兼容），用于 Agent 回答页真实调用
# 复制为 .env 并填写后，在首页发送消息将请求大模型并展示回复
#
# 可接的 Key（任选其一，用对应厂商的 base URL + 该厂商的 API Key）：
#
#   OpenAI     VITE_LLM_API_BASE_URL=https://api.openai.com
#   Azure OpenAI  需在 Azure 门户创建部署，base URL 形如 https://<your-resource>.openai.azure.com/openai/deployments/<deployment>
#   DeepSeek  VITE_LLM_API_BASE_URL=https://api.deepseek.com
#   通义千问  VITE_LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   智谱 GLM  VITE_LLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   月之暗面 Moonshot  VITE_LLM_API_BASE_URL=https://api.moonshot.cn/v1
#   百川      见官网 OpenAI 兼容文档
#   零一万物  见官网 OpenAI 兼容文档
#   其他      凡提供 OpenAI 兼容 /v1/chat/completions 的服务均可
#
# 接口地址（末尾不要加 /v1/chat/completions，程序会自动拼接）
VITE_LLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 该厂商的 API Key（在对应官网/控制台申请）
VITE_LLM_API_KEY=41dc9661d5ed4542aba4337fb024128a.2LncuNJ6zo3xx87U

# 可选：模型名，不填则使用默认（如 gpt-4o-mini）。不同厂商模型名不同，见各厂商文档
# VITE_LLM_MODEL=glm-4.7
